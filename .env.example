# ObsForge environment variables
# Copy this file to .env and fill in your values before running the scripts.
# .env is git-ignored — never commit it.

# ------------------------------------------------------------------
# Cluster identity
# This value ends up in Prometheus external_labels as `cluster`.
# ------------------------------------------------------------------
CLUSTER_NAME=prod
AWS_REGION=us-east-1

# ------------------------------------------------------------------
# Object storage — AWS S3 (primary platform)
#
# For GCP:   set GCS_BUCKET_NAME, flip type to GCS in bucket.yml.example
# For Azure: set AZURE_STORAGE_ACCOUNT, flip type to AZURE
# ------------------------------------------------------------------
S3_BUCKET_NAME=your-thanos-metrics-bucket

# Leave blank when using IRSA (EKS IAM role for service accounts).
# For IRSA setup see k8s/prometheus/rbac.yml.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# GCP / Azure (unused unless you switch the bucket config)
# GCS_BUCKET_NAME=
# GCP_PROJECT=
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_CONTAINER_NAME=

# ------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change-me-before-deploy

# ------------------------------------------------------------------
# Retention — applied by Thanos Compactor
# Raw samples, 5-minute downsampled copies, 1-hour downsampled copies.
# ------------------------------------------------------------------
RETENTION_RAW=30d
RETENTION_5M=90d
RETENTION_1H=1y

# ------------------------------------------------------------------
# Local docker-compose only (MinIO as S3 substitute)
# ------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
