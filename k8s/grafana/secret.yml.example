#
# scripts/create-secrets.sh generates and applies this from GRAFANA_ADMIN_PASSWORD in .env.
apiVersion: v1
kind: Secret
metadata:
  name: grafana-secret
  namespace: monitoring
  labels:
    app: grafana
    app.kubernetes.io/part-of: obsforge
type: Opaque
stringData:
  admin-password: "change-me-before-deploy"
