# 
# scripts/create-secrets.sh generates and applies this from your .env file.
#
# The bucket.yml value is the filled-in contents of config/thanos/bucket.yml.example.
apiVersion: v1
kind: Secret
metadata:
  name: thanos-objstore
  namespace: monitoring
  labels:
    app.kubernetes.io/part-of: obsforge
type: Opaque
stringData:
  bucket.yml: |
    type: S3
    config:
      bucket: YOUR_S3_BUCKET_NAME
      endpoint: s3.YOUR_REGION.amazonaws.com
      region: YOUR_REGION
      access_key: YOUR_ACCESS_KEY_ID
      secret_key: YOUR_SECRET_ACCESS_KEY
